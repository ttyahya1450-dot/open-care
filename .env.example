# Copy this file to .env.local for local development.
# In production, set these in Vercel Dashboard > Settings > Environment Variables
# or pass them to Docker via:  docker run --env-file .env.production <image>

# ── Stripe Connect ────────────────────────────────────────────────────────
# Required for all payment, payout, and compliance API routes.
# Development:  sk_test_...  (dashboard.stripe.com/test/apikeys)
# Production:   sk_live_...  (dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME

# Optional — client-side Stripe.js initialisation (not yet wired in MVP)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Webhook signing secret — Dashboard > Developers > Webhooks > your endpoint.
# Required events: payment_intent.succeeded, payment_intent.payment_failed,
#                  account.updated, transfer.created
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# ── Google Maps ───────────────────────────────────────────────────────────
# Server-side only — Distance Matrix API for GPS shift check-in verification.
# Optional: if absent, geofence falls back to Haversine formula (200 m radius).
# Create key at: console.cloud.google.com/apis/credentials
# Enable: Distance Matrix API, Maps JavaScript API, Geocoding API
GOOGLE_MAPS_API_KEY=REPLACE_ME

# ── App ───────────────────────────────────────────────────────────────────
# Deployed Next.js base URL — used by Capacitor live-server mode
NEXT_PUBLIC_APP_URL=https://app.opencare.com.au
