# ── Stripe Connect ──────────────────────────────────────────────────────────
# Live keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook signing secret from https://dashboard.stripe.com/webhooks
# Events required: payment_intent.succeeded, payment_intent.payment_failed,
#                  account.updated, transfer.created
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Google Maps ─────────────────────────────────────────────────────────────
# Enable: Distance Matrix API, Maps JavaScript API, Geocoding API
# https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=AIza...

# ── App ─────────────────────────────────────────────────────────────────────
# Deployed Next.js URL — used by Capacitor live-server mode (capacitor.config.ts)
NEXT_PUBLIC_APP_URL=https://app.opencare.com.au
